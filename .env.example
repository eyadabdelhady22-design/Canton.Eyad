# Copy to .env and fill in, or `export` these before running cn.py.
# The hackathon client secret is NOT committed to this repo.
CANTON_CLIENT_SECRET=your-hackathon-client-secret-here

# Optional overrides (defaults target the C8/Cantor8 DevNet validator):
# CANTON_IDP_BASE=https://auth.dev.digik.cantor8.tech
# CANTON_CLIENT_ID=hackathon
